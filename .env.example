# AAYA — Member A Environment Variables
# Copy this file to .env and fill in your keys

# Claude API Key (required for LLM layer, Future Self, Agents)
REACT_APP_ANTHROPIC_API_KEY=your_claude_api_key_here

# Google Maps API Key (optional — replace Leaflet map in MapTracker.jsx)
REACT_APP_GOOGLE_MAPS_KEY=your_google_maps_key_here

# Bhashini API (optional — for production NLP beyond Web Speech API)
REACT_APP_BHASHINI_KEY=your_bhashini_key_here
